{
  "name": "cc_aws_portfolio_plugin",
  "runArgs": ["--name", "cc_aws_portfolio_plugin"],
  "image": "mcr.microsoft.com/devcontainers/base:bookworm",
  "workspaceFolder": "/workspaces/cc_aws_portfolio_plugin",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "containerEnv": {
    "PULSE_SERVER": "tcp:host.docker.internal:4713",
    "AUDIODRIVER": "pulseaudio"
  },
  "postCreateCommand": "bash .devcontainer/install-tools.sh && if [ -f package.json ]; then npm install; fi"
}
